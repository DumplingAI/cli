{
  "name": "dumplingai-cli",
  "version": "0.2.0",
  "description": "DumplingAI CLI — discover and execute Unified API Platform capabilities from the terminal",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "dumplingai": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "dumplingai",
    "cli",
    "ai",
    "agent",
    "unified-api",
    "capabilities",
    "providers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DumplingAI/cli"
  },
  "homepage": "https://www.dumplingai.com",
  "bugs": {
    "url": "https://github.com/dumplingai/cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bundle-skills": "node scripts/bundle-skills.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm run bundle-skills",
    "build": "pnpm run clean && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src tests",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
